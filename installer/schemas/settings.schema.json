{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Settings Schema",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Settings format version"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Agent name"
          },
          "path": {
            "type": "string",
            "description": "Absolute or relative path to agent definition file"
          },
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether the agent is enabled"
          },
          "config": {
            "type": "object",
            "description": "Agent-specific configuration",
            "properties": {
              "model": {
                "type": "string",
                "enum": ["sonnet", "haiku", "opus"]
              },
              "temperature": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "maxTokens": {
                "type": "integer",
                "minimum": 100
              }
            }
          }
        }
      },
      "description": "List of configured agents"
    },
    "defaults": {
      "type": "object",
      "description": "Default settings for all agents",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["sonnet", "haiku", "opus"],
          "default": "sonnet"
        },
        "temperature": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.7
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 100,
          "default": 4000
        }
      }
    }
  }
}
